[sub_resource type="Resource" id="Resource_da002"]
script = ExtResource("2_7j066")
text = "¿Todo bien?"
time = "06/11 14:45"
sent = true
metadata/_custom_type_script = "uid://gdiumfglcp6n"

[sub_resource type="Resource" id="Resource_da003"]
script = ExtResource("2_7j066")
text = "Sí sí. Mejor en persona nomás"
time = "06/11 14:47"
metadata/_custom_type_script = "uid://gdiumfglcp6n"

[sub_resource type="Resource" id="Resource_da004"]
script = ExtResource("2_7j066")
text = "¿Llegaste a revisar lo que te mandé?"
time = "10/11 09:15"
metadata/_custom_type_script = "uid://gdiumfglcp6n"

[sub_resource type="Resource" id="Resource_da005"]
script = ExtResource("2_7j066")
text = "Sí. Necesito un par de días más"
time = "10/11 10:02"
sent = true
metadata/_custom_type_script = "uid://gdiumfglcp6n"

[sub_resource type="Resource" id="Resource_da006"]
script = ExtResource("2_7j066")
text = "Marcelo, hay gente que está incómoda con los tiempos"
time = "10/11 10:04"
metadata/_custom_type_script = "uid://gdiumfglcp6n"

[sub_resource type="Resource" id="Resource_da007"]
script = ExtResource("2_7j066")
text = "Entiendo. Pero necesito estar seguro antes de decir cualquier cosa"
time = "10/11 10:10"
sent = true
metadata/_custom_type_script = "uid://gdiumfglcp6n"

[sub_resource type="Resource" id="Resource_da008"]
script = ExtResource("2_7j066")
text = "Seguro de qué, si ya está todo cerrado"
time = "10/11 10:11"
metadata/_custom_type_script = "uid://gdiumfglcp6n"

[sub_resource type="Resource" id="Resource_da009"]
script = ExtResource("2_7j066")
text = "Precisamente por eso necesito tiempo. No sigas por acá"
time = "10/11 10:15"
sent = true
