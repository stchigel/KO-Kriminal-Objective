nombre = "vhalac@museobbaarrosario.gob.ar"
asunto = "Documentación obra Soldi — solicitud urgente"
mensaje = "Marcelo, te reenvío el contrato de cesión de la obra \"Tarde en el parque\" (atrib. Soldi, 1947) que recibimos a través de Artes del Sur SRL en 2023. El firmante fue un tal Rodrigo Iturbe. La empresa fue disuelta en agosto de 2024. Te adjunto todo, esperamos tu análisis."
