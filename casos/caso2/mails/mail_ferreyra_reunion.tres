script = ExtResource("1_0co7v")
nombre = "dferreyra@estudiomeridiano.com.ar"
asunto = "Re: Reunión miércoles"
mensaje = "Marcelo, estás viendo solo una parte del cuadro. Hay personas involucradas que no van a esperar tranquilas a que vos \"hagas lo correcto\". Yo también estoy entre la espada y la pared. Las obras ya están colocadas, el dinero ya circuló. Remover esto ahora no salva a nadie, solo nos hunde a todos."
