sent = true
metadata/_custom_type_script = "uid://gdiumfglcp6n"

[sub_resource type="Resource" id="Resource_x0uql"]
script = ExtResource("2_7j066")
text = "Perfecto. Oye, ¿también sacaste fotos de la zona de cajas?"
