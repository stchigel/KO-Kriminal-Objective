text = "Sí, ¿por qué?"
time = "17/10 18:30"
sent = true
metadata/_custom_type_script = "uid://gdiumfglcp6n"

[sub_resource type="Resource" id="Resource_a1932"]
script = ExtResource("2_7j066")
text = "Por nada, curiosidad. ¿Las tenés todas en la cámara todavía?"
time = "17/10 18:33"
metadata/_custom_type_script = "uid://gdiumfglcp6n"

[sub_resource type="Resource" id="Resource_72d19"]
script = ExtResource("2_7j066")
text = "Algunas sí, otras ya las pasé a la compu. ¿Por qué me preguntás eso?"
time = "17/10 18:36"
sent = true
metadata/_custom_type_script = "uid://gdiumfglcp6n"

[sub_resource type="Resource" id="Resource_ac6a5"]
script = ExtResource("2_7j066")
text = "Nada amor, tranquilo. ¿Nos vemos el viernes?"
time = "17/10 18:40"
metadata/_custom_type_script = "uid://gdiumfglcp6n"

[sub_resource type="Resource" id="Resource_6e85a"]
script = ExtResource("2_7j066")
text = "Sí, pasá por casa."
