[node name="Diario" parent="." unique_id=226651584 instance=ExtResource("35_31h3k")]
visible = false
layout_mode = 0
offset_left = 440.0
offset_top = 112.0
offset_right = 760.0
offset_bottom = 560.0
texto = "Diario de viaje — Italia, octubre de 1998 [br]Marcelo A. Vidal [br] [br]--- [br] [br]Milán, 3 de octubre [br] [br]El vuelo llegó con una hora de retraso y la valija de Guillermo tardó veinte minutos más que la mía. Primer contratiempo del viaje, primero de muchos según él. Yo le dije que era buena señal: lo peor ya había pasado. No me creyó. [br] [br]El hotel está bien ubicado, cerca de la estación. Mañana tomamos el tren a Venecia. [br] [br]--- [br] [br]Venecia, 5 de octubre [br] [br]No hay palabras para esto. Lo intenté igual. [br] [br]El Gran Canal a la mañana temprano, con la niebla todavía pegada al agua, tiene algo de irreal. Guillermo sacó fotos sin parar. Yo preferí mirar. Hay cosas que una cámara no termina de capturar — la humedad en el aire, el sonido del agua contra la piedra, el olor. [br] [br]Visitamos San Marcos por la tarde. Impresionante, claro. Pero me quedé pensando en que lo más extraordinario todavía estaba por venir. [br] [br]--- [br] [br]Padua, 7 de octubre [br] [br]Hoy fue el día. [br] [br]Salimos temprano desde Venecia. Guillermo protestó por el horario pero una vez adentro de la Capilla Scrovegni no dijo nada más. Ninguno de los dos dijo nada por un buen rato. [br] [br]Giotto pintó esas paredes entre 1304 y 1306. Setecientos años mirándote. El ciclo entero de la vida de la Virgen y de Cristo, dispuesto con una claridad y una emoción que no había visto en ninguna reproducción. Las fotos mienten. Los libros mienten. Hay que estar ahí. [br] [br]Pero el fresco que me detuvo, el que no pude dejar de ver, fue La Lamentación de Cristo. [br] [br]María sostiene el cuerpo de Jesús bajado de la cruz. Las figuras se inclinan sobre él en distintos ángulos de dolor. Cada rostro es distinto, cada gesto particular. No es una escena genérica de sufrimiento: es un grupo de personas específicas, con nombres, con historia, atravesadas por algo que no tienen palabras para nombrar. En el cielo, ángeles diminutos lloran con una desesperación casi violenta, retorcidos en el aire. [br] [br]Giotto pintó el dolor como si lo conociera desde adentro. [br] [br]Me quedé parado frente a ese fresco más tiempo del que debería. Guillermo al final me puso una mano en el hombro y no dijo nada. A veces la amistad es eso. [br] [br]En el tren de vuelta a Venecia, ninguno de los dos habló del fresco directamente. Hablamos de otra cosa, de la cena, del día siguiente. Pero yo no podía dejar de verlo. [br] [br]Creo que hay obras que te cambian algo adentro, aunque no sepas exactamente qué. [br] [br]La Lamentación de Cristo. Giotto. Padua, 1998. [br] [br]No voy a olvidar ese día. [br] [br]--- [br] [br]Venecia, 9 de octubre — último día [br] [br]Compramos regalos, caminamos sin destino, tomamos el vaporetto por última vez. Guillermo perdió un guante en algún puente y decidió que era \"el precio del viaje\". [br] [br]Mañana vuelta a casa. [br] [br]Italia me devuelve algo que Buenos Aires, sin querer, a veces me quita: la certeza de que hay cosas hechas para durar. [br] [br]— M.V. [br]"
nombre = "diario_venecia_1998.txt"

